# ─── Better Auth (self-hosted, sessions stored in your Neon DB) ───────────────
# Random secret — never share this. Must be 32+ chars.
BETTER_AUTH_SECRET=<random-32-char-secret>

# Your app URL (change to your production URL when deploying)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ─── Admin access ─────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that have admin dashboard access.
# REQUIRED — if left empty, ALL authenticated users will be DENIED admin access.
ADMIN_EMAILS=admin@example.com

# ─── Neon Postgres ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require&channel_binding=require

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Used by @ai-sdk/google (chat, marketing, insights, etc.)
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# Used by FastAPI / HuggingFace pipeline
HF_TOKEN=hf_...
GEMINI_API_KEY=AIza...
FASTAPI_URL=http://localhost:8000

# ─── Upstash Redis (optional — session signal cache) ─────────────────────────
UPSTASH_REDIS_REST_URL=https://<your-upstash-endpoint>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# ─── Payment webhook ──────────────────────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=<set-a-strong-shared-secret>
